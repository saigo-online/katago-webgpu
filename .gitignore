web/demo/engine.js
web/demo/engine.wasm
web/demo/kataeval.js
web/demo/kataeval.wasm
web/demo/kataeval.wasm.map
web/demo/*_dbg.*
# self-signed TLS certs from serve-demo-tls.sh
web/.certs/
# neural net weights — re-bundled by build-eval.sh, don't commit the blobs
web/demo/model.bin.gz
web/demo/model-*.bin.gz


