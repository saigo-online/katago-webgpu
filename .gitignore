# ============================================================================
# katago-web: WebGPU backend + browser build artifacts (keep the repo lean)
# NOTE: .gitignore has no inline comments — keep comments on their own lines.
# ============================================================================
# Dawn source/build/install (~GBs; built by scripts/build-webgpu.sh)
third_party/
# native builds
cpp/build-webgpu/
cpp/build-eigen/
cpp/build-wasm/
node_modules/
# generated web artifacts (built by scripts/build-web.sh / build-eval.sh)
